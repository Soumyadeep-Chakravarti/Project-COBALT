---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const logs = await getCollection('logs');
const sortedLogs = logs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(logs.flatMap(log => log.data.tags || []))];
---

<Layout title="logs" description="Engineering logs - the full timeline of building COBALT from genesis to present. Brain dumps, breakthroughs, and lessons learned.">
  <header class="logs-header">
    <h1 class="title">
      <span class="bracket">[</span> logs <span class="bracket">]</span>
    </h1>
    <p class="subtitle">the full timeline - in order of discovery</p>
  </header>

  <div class="filters">
    <div class="filter-group">
      <span class="filter-label">Tags:</span>
      <div class="filter-tags">
        <button class="filter-btn active" data-filter="all">All</button>
        {allTags.map(tag => (
          <button class="filter-btn" data-filter={tag}>#{tag}</button>
        ))}
      </div>
    </div>
  </div>

  <div class="logs-list" id="logs-list">
    {sortedLogs.map(log => (
      <a href={`/logs/${log.id}`} class="log-card" data-tags={JSON.stringify(log.data.tags || [])}>
        <div class="log-id">{log.id.toUpperCase()}</div>
        <div class="log-info">
          <h2 class="log-title">{log.data.title}</h2>
          <div class="log-meta">
            <span class="log-date">{log.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            <span class="log-category">{log.data.categories?.[0]}</span>
          </div>
        </div>
        <div class="log-arrow">→</div>
      </a>
    ))}
  </div>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const logCards = document.querySelectorAll('.log-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      logCards.forEach(card => {
        const tags = JSON.parse(card.dataset.tags || '[]');
        if (filter === 'all' || tags.includes(filter)) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .logs-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2rem;
    font-weight: 900;
    color: var(--cobalt);
    letter-spacing: -1px;
  }

  .bracket {
    color: var(--text-dim);
  }

  .subtitle {
    color: var(--text-dim);
    margin-top: 0.5rem;
  }

  .filters {
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--bg-card);
    border-radius: 8px;
    border: 1px solid rgba(0, 212, 255, 0.1);
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-btn {
    background: transparent;
    border: 1px solid rgba(0, 212, 255, 0.1);
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    padding: 0.35rem 0.7rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    border-color: var(--cobalt);
    color: var(--cobalt);
  }

  .filter-btn.active {
    background: rgba(0, 212, 255, 0.15);
    border-color: var(--cobalt);
    color: var(--cobalt);
  }

  .logs-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .log-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s ease;
    animation: fadeIn 0.4s ease-out backwards;
  }

  .log-card:nth-child(1) { animation-delay: 0.05s; }
  .log-card:nth-child(2) { animation-delay: 0.1s; }
  .log-card:nth-child(3) { animation-delay: 0.15s; }
  .log-card:nth-child(4) { animation-delay: 0.2s; }
  .log-card:nth-child(5) { animation-delay: 0.25s; }
  .log-card:nth-child(6) { animation-delay: 0.3s; }
  .log-card:nth-child(7) { animation-delay: 0.35s; }
  .log-card:nth-child(8) { animation-delay: 0.4s; }
  .log-card:nth-child(9) { animation-delay: 0.45s; }

  .log-card:hover {
    border-color: var(--cobalt);
    transform: translateX(12px) scale(1.01);
    box-shadow: 0 8px 30px var(--glow);
  }

  .log-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    font-weight: 700;
    color: var(--cobalt);
    min-width: 80px;
  }

  .log-info {
    flex: 1;
  }

  .log-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .log-meta {
    display: flex;
    gap: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .log-arrow {
    font-family: 'JetBrains Mono', monospace;
    color: var(--cobalt);
    font-size: 1.5rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .log-card:hover .log-arrow {
    opacity: 1;
  }
</style>