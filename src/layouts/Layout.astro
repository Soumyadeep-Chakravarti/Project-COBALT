---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "The cognitive core of a custom AR-based Operating System. Polyglot infrastructure. 9 languages. 11 layers." } = Astro.props;
const site = "https://cobalt.engineering";
const socialImage = site + "/og-image.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site} />
    <meta property="og:title" content={title + " | c0balt"} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title + " | c0balt"} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    
    <title>{title} | c0balt</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet"></noscript>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script type="module">
      await new Promise(r => setTimeout(r, 0));
      
      async function initMermaid() {
        try {
          const mermaid = await import('https://cdn.jsdelivr.net/npm/mermaid@10.9.0/dist/mermaid.esm.min.mjs');
          const m = mermaid.default;
          
          m.initialize({ 
            startOnLoad: false, 
            securityLevel: 'loose',
            theme: document.documentElement.classList.contains('light') ? 'default' : 'dark'
          });
          
          const els = document.querySelectorAll('pre.mermaid');
          console.log('Found', els.length, 'mermaid elements');
          
          for (let i = 0; i < els.length; i++) {
            const el = els[i];
            const id = 'mermaid-' + i;
            const code = el.textContent.trim();
            console.log('Rendering diagram', i, 'length:', code.length);
            console.log('Code:', code.substring(0, 60));
            
            try {
              const { svg } = await m.render(id, code);
              console.log('Success diagram', i, '- SVG length:', svg.length);
              el.innerHTML = svg;
              el.setAttribute('data-processed', 'true');
            } catch (err) {
              console.error('Mermaid render error', i + ':', err.message);
              console.error('Error details:', err);
              el.textContent = 'Diagram error: ' + err.message;
            }
          }
        } catch (err) {
          console.error('Mermaid init error:', err);
        }
      }
      
      initMermaid();
    </script>
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="scroll-progress" id="scroll-progress"></div>
    <nav class="logic-gate-nav">
      <!-- Main trunk SVG -->
      <svg class="circuit-svg" viewBox="0 0 400 80" preserveAspectRatio="none">
        <!-- Main trunk line -->
        <path class="circuit-line" d="M 20 75 L 20 40 L 380 40" />
        <!-- Branch to logs -->
        <path class="circuit-line branch-logs" d="M 70 40 L 70 30" />
        <!-- Branch to stack -->
        <path class="circuit-line branch-stack" d="M 150 40 L 150 30" />
        <!-- Branch to arch -->
        <path class="circuit-line branch-arch" d="M 230 40 L 230 30" />
        <!-- Branch to search -->
        <path class="circuit-line branch-search" d="M 310 40 L 310 30" />
        <!-- Active glow bead -->
        <circle class="data-bead" cx="20" cy="75" r="4">
          <animateMotion dur="3s" repeatCount="indefinite" path="M 20 75 L 20 40 L 380 40" />
        </circle>
      </svg>
      
      <div class="nav-content">
        <a href="/" class="logo">
          <span class="bracket">[</span>c0balt<span class="bracket">]</span>
        </a>
        <div class="nav-links">
          <a href="/logs" class="nav-node" data-branch="logs">
            <span class="node-dot"></span>
            <span class="node-label">logs</span>
          </a>
          <a href="/stack" class="nav-node" data-branch="stack">
            <span class="node-dot"></span>
            <span class="node-label">stack</span>
          </a>
          <a href="/architecture" class="nav-node" data-branch="arch">
            <span class="node-dot"></span>
            <span class="node-label">arch</span>
          </a>
          <a href="/search" class="nav-node" data-branch="search">
            <span class="node-dot"></span>
            <span class="node-label">search</span>
          </a>
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
            <span class="sun-icon">☀</span>
            <span class="moon-icon">☾</span>
          </button>
          <a href="https://github.com/Soumyadeep-Chakravarti" target="_blank" rel="noopener noreferrer" class="nav-node">
            <span class="node-dot"></span>
            <span class="node-label">gh</span>
          </a>
        </div>
      </div>
    </nav>
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <span class="terminal-prompt">></span> abstraction is a weapon
    </footer>
    <script>
      const progress = document.getElementById('scroll-progress');
      window.addEventListener('scroll', () => {
        const scrolled = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        progress.style.width = scrolled + '%';
      });

      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle');
      themeBtn?.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        location.reload();
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --cobalt: #00d4ff;
    --cobalt-dim: #0088aa;
    --bg-dark: #0a0a0f;
    --bg-card: #12121a;
    --text: #e0e0e0;
    --text-dim: #666;
    --accent: #ff3366;
    --success: #00ff88;
    --warning: #ffaa00;
    --glow: rgba(0, 212, 255, 0.4);
    --border: rgba(0, 212, 255, 0.15);
  }

  :root.light {
    --cobalt: #0891b2;
    --cobalt-dim: #0e7490;
    --bg-dark: #f8fafc;
    --bg-card: #f1f5f9;
    --text: #1e293b;
    --text-dim: #64748b;
    --accent: #e11d48;
    --success: #059669;
    --warning: #d97706;
    --glow: rgba(8, 145, 178, 0.3);
    --border: rgba(8, 145, 178, 0.2);
  }

  :root {
    --neon-pink: #ff0080;
    --neon-cyan: #00ffff;
    --neon-purple: #a855f7;
    --neon-green: #00ff88;
  }

  :root.light {
    --neon-pink: #db2777;
    --neon-cyan: #0891b2;
    --neon-purple: #7c3aed;
    --neon-green: #059669;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Skip link for keyboard users */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: var(--cobalt);
    color: var(--bg-dark);
    padding: 8px 16px;
    z-index: 10000;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    transition: top 0.2s;
  }

  .skip-link:focus {
    top: 0;
  }

  /* Focus styles */
  a:focus, button:focus, input:focus {
    outline: 2px solid var(--cobalt);
    outline-offset: 2px;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  html {
    font-family: 'Outfit', sans-serif;
    background: var(--bg-dark);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    background: var(--bg-dark);
  }

  main {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--cobalt);
    box-shadow: 0 0 10px var(--cobalt), 0 0 20px var(--cobalt);
    z-index: 1001;
    transition: width 0.1s;
    animation: scrollGlow 1.5s ease-in-out infinite;
  }

  @keyframes scrollGlow {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 1; }
  }

  .logic-gate-nav {
    display: grid;
    grid-template-columns: 1fr;
    padding: 0.5rem 2rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-dark);
    position: sticky;
    top: 0;
    z-index: 100;
    overflow: visible;
  }

  .circuit-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.15;
  }

  .circuit-line {
    fill: none;
    stroke: var(--cobalt);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .data-bead {
    fill: var(--cobalt);
    filter: drop-shadow(0 0 6px var(--cobalt));
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  :root.light .circuit-svg {
    opacity: 0.1;
  }

  .nav-node {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.6rem;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .nav-node:hover {
    background: rgba(0, 212, 255, 0.1);
  }

  .node-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cobalt);
    opacity: 0.3;
    transition: all 0.3s ease;
  }

  .nav-node:hover .node-dot {
    opacity: 1;
    box-shadow: 0 0 6px var(--cobalt);
  }

  .node-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .nav-node:hover .node-label {
    color: var(--cobalt);
  }

  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cobalt);
    text-decoration: none;
    letter-spacing: -1px;
    animation: neonGlow 2s ease-in-out infinite alternate;
  }

  @keyframes neonGlow {
    from {
      text-shadow: 0 0 4px var(--cobalt), 0 0 10px var(--cobalt), 0 0 20px var(--cobalt);
    }
    to {
      text-shadow: 0 0 2px var(--cobalt), 0 0 5px var(--cobalt), 0 0 10px var(--cobalt);
    }
  }

  .bracket {
    color: var(--text-dim);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .theme-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--cobalt);
    padding: 0.4rem 0.6rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-btn:hover {
    border-color: var(--cobalt);
    box-shadow: 0 0 15px var(--glow);
  }

  .sun-icon { display: none; }
  .moon-icon { display: block; }

  :root.light .sun-icon { display: block; }
  :root.light .moon-icon { display: none; }

  .nav-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 1px;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--cobalt);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--cobalt);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    border-top: 1px solid rgba(0, 212, 255, 0.1);
  }

  .terminal-prompt {
    color: var(--cobalt);
    animation: cursorBlink 1s step-end infinite, cursorGlow 2s ease-in-out infinite alternate;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
  }

  @keyframes cursorGlow {
    from { text-shadow: 0 0 3px var(--cobalt); }
    to { text-shadow: 0 0 12px var(--cobalt), 0 0 20px var(--cobalt); }
  }

  /* Syntax highlighting overrides */
  pre code.hljs {
    background: var(--bg-card);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    border: 1px solid var(--border);
  }

  code.hljs {
    background: var(--bg-card);
    padding: 0.2rem 0.4rem;
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .logic-gate-nav {
      padding: 0.5rem 1rem;
    }
    .nav-content {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .circuit-svg {
      display: none;
    }
    .node-label {
      display: none;
    }
    main {
      padding: 1.5rem;
    }
  }

  /* Mermaid diagram styling */
  pre.mermaid {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 2rem 0;
    padding: 1rem;
    background-color: transparent;
    border: none;
    overflow: auto;
    min-height: 200px;
  }

  pre.mermaid:not([data-processed]) {
    background: linear-gradient(90deg, #2a2a2a 25%, #3a3a3a 50%, #2a2a2a 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  pre.mermaid[data-processed] {
    animation: none;
    background: transparent;
    min-height: auto;
  }

  pre.mermaid svg {
    max-width: 100%;
    height: auto;
  }

  /* Light mode mermaid overrides */
  :root.light pre.mermaid:not([data-processed]) {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  }

  /* Mermaid SVG theme overrides - Dark mode */
  pre.mermaid svg .node rect,
  pre.mermaid svg .node polygon,
  pre.mermaid svg .node circle {
    fill: #12121a !important;
    stroke: #00d4ff !important;
  }
  pre.mermaid svg .node .label,
  pre.mermaid svg .label {
    fill: #e0e0e0 !important;
    color: #e0e0e0 !important;
  }
  pre.mermaid svg .edgePath path,
  pre.mermaid svg .edge-path path {
    stroke: #00d4ff !important;
  }
  pre.mermaid svg .cluster rect,
  pre.mermaid svg .cluster polygon {
    fill: #12121a !important;
    stroke: #00d4ff !important;
  }
  pre.mermaid svg text {
    fill: #e0e0e0 !important;
  }

  /* Mermaid SVG theme overrides - Light mode */
  :root.light pre.mermaid svg .node rect,
  :root.light pre.mermaid svg .node polygon,
  :root.light pre.mermaid svg .node circle {
    fill: #f1f5f9 !important;
    stroke: #0891b2 !important;
  }
  :root.light pre.mermaid svg .node .label,
  :root.light pre.mermaid svg .label {
    fill: #1e293b !important;
    color: #1e293b !important;
  }
  :root.light pre.mermaid svg .edgePath path,
  :root.light pre.mermaid svg .edge-path path {
    stroke: #0891b2 !important;
  }
  :root.light pre.mermaid svg .cluster rect,
  :root.light pre.mermaid svg .cluster polygon {
    fill: #f1f5f9 !important;
    stroke: #0891b2 !important;
  }
  :root.light pre.mermaid svg text {
    fill: #1e293b !important;
  }
</style>