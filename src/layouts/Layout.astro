---
const base = import.meta.env.BASE_URL;

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The cognitive core of a custom AR-based Operating System. Polyglot infrastructure. 9 languages. 11 layers." } = Astro.props;
const site = "https://soumyadeep-chakravarti.github.io/Project-COBALT";
const socialImage = site + "/og-image.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={base + "favicon.svg"} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site} />
    <meta property="og:title" content={`${title} | c0balt`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={site} />
    <meta name="twitter:title" content={`${title} | c0balt`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    
    <title>{title} | c0balt</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet"></noscript>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">

    <script type="module">
      await new Promise(r => setTimeout(r, 0));
      
      async function initMermaid() {
        try {
          const mermaid = await import('https://cdn.jsdelivr.net/npm/mermaid@10.9.0/dist/mermaid.esm.min.mjs');
          const m = mermaid.default;
          
          m.initialize({ 
            startOnLoad: false, 
            securityLevel: 'loose',
            theme: document.documentElement.classList.contains('light') ? 'default' : 'dark'
          });
          
          const els = document.querySelectorAll('pre.mermaid');
          for (let i = 0; i < els.length; i++) {
            const el = els[i];
            const id = 'mermaid-' + i;
            const code = el.textContent.trim();
            
            try {
              const { svg } = await m.render(id, code);
              el.innerHTML = svg;
              el.setAttribute('data-processed', 'true');
            } catch (err) {
              console.error(`Mermaid render error ${i}:`, err.message);
              el.textContent = 'Diagram error: ' + err.message;
            }
          }
        } catch (err) {
          console.error('Mermaid init error:', err);
        }
      }
      initMermaid();
    </script>

    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="scroll-progress" id="scroll-progress"></div>
    
    <nav class="logic-gate-nav">
      <svg class="circuit-svg" viewBox="0 0 400 80" preserveAspectRatio="none">
        <path class="circuit-line" d="M 20 75 L 20 40 L 380 40" />
        <path class="circuit-line branch-logs" d="M 70 40 L 70 30" />
        <path class="circuit-line branch-stack" d="M 150 40 L 150 30" />
        <path class="circuit-line branch-arch" d="M 230 40 L 230 30" />
        <path class="circuit-line branch-search" d="M 310 40 L 310 30" />
        <circle class="data-bead" cx="20" cy="75" r="4">
          <animateMotion dur="3s" repeatCount="indefinite" path="M 20 75 L 20 40 L 380 40" />
        </circle>
      </svg>
      
      <div class="nav-content">
        <a href={base} class="logo">
          <span class="bracket">[</span>c0balt<span class="bracket">]</span>
        </a>
        <div class="nav-links">
          <a href={base + "logs"} class="nav-node" data-branch="logs">
            <span class="node-dot"></span>
            <span class="node-label">logs</span>
          </a>
          <a href={base + "stack"} class="nav-node" data-branch="stack">
            <span class="node-dot"></span>
            <span class="node-label">stack</span>
          </a>
          <a href={base + "architecture"} class="nav-node" data-branch="arch">
            <span class="node-dot"></span>
            <span class="node-label">arch</span>
          </a>
          <a href={base + "search"} class="nav-node" data-branch="search">
            <span class="node-dot"></span>
            <span class="node-label">search</span>
          </a>
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
            <span class="sun-icon">☀</span>
            <span class="moon-icon">☾</span>
          </button>
          <a href="https://github.com/Soumyadeep-Chakravarti" target="_blank" rel="noopener noreferrer" class="nav-node">
            <span class="node-dot"></span>
            <span class="node-label">gh</span>
          </a>
        </div>
      </div>
    </nav>

    <main id="main-content">
      <slot />
    </main>

    <footer>
      <span class="terminal-prompt">></span> abstraction is a weapon
    </footer>

    <script>
      // Scroll Progress
      const progress = document.getElementById('scroll-progress');
      window.addEventListener('scroll', () => {
        const scrolled = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        if (progress) progress.style.width = scrolled + '%';
      });

      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle');
      themeBtn?.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        location.reload(); 
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --cobalt: #00d4ff;
    --cobalt-dim: #0088aa;
    --bg-dark: #0a0a0f;
    --bg-card: #12121a;
    --text: #e0e0e0;
    --text-dim: #666;
    --accent: #ff3366;
    --success: #00ff88;
    --warning: #ffaa00;
    --glow: rgba(0, 212, 255, 0.4);
    --border: rgba(0, 212, 255, 0.15);
    --neon-pink: #ff0080;
    --neon-cyan: #00ffff;
    --neon-purple: #a855f7;
    --neon-green: #00ff88;
  }

  :root.light {
    --cobalt: #0891b2;
    --cobalt-dim: #0e7490;
    --bg-dark: #f8fafc;
    --bg-card: #f1f5f9;
    --text: #1e293b;
    --text-dim: #64748b;
    --accent: #e11d48;
    --success: #059669;
    --warning: #d97706;
    --glow: rgba(8, 145, 178, 0.3);
    --border: rgba(8, 145, 178, 0.2);
    --neon-pink: #db2777;
    --neon-cyan: #0891b2;
    --neon-purple: #7c3aed;
    --neon-green: #059669;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    font-family: 'Outfit', sans-serif;
    background: var(--bg-dark);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body { min-height: 100vh; position: relative; overflow-x: hidden; }

  .skip-link {
    position: absolute; top: -40px; left: 0;
    background: var(--cobalt); color: var(--bg-dark);
    padding: 8px 16px; z-index: 10000;
    text-decoration: none; font-family: 'JetBrains Mono', monospace;
    transition: top 0.2s;
  }
  .skip-link:focus { top: 0; }

  .scroll-progress {
    position: fixed; top: 0; left: 0; width: 0%; height: 2px;
    background: var(--cobalt); z-index: 1001;
    box-shadow: 0 0 10px var(--cobalt);
  }

  .logic-gate-nav {
    display: grid; padding: 0.5rem 2rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-dark); position: sticky; top: 0; z-index: 100;
  }

  .circuit-svg {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; opacity: 0.15;
  }

  .circuit-line { fill: none; stroke: var(--cobalt); stroke-width: 2; }
  .data-bead { fill: var(--cobalt); filter: drop-shadow(0 0 6px var(--cobalt)); }

  .nav-content { display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1; }
  .nav-links { display: flex; gap: 2rem; align-items: center; }
  .nav-node { display: flex; align-items: center; gap: 0.4rem; text-decoration: none; }
  .node-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--cobalt); opacity: 0.3; }
  .node-label { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--text-dim); }

  .nav-node:hover .node-dot { opacity: 1; box-shadow: 0 0 6px var(--cobalt); }
  .nav-node:hover .node-label { color: var(--cobalt); }

  .logo {
    font-family: 'JetBrains Mono', monospace; font-size: 1.5rem; font-weight: 700;
    color: var(--cobalt); text-decoration: none;
    text-shadow: 0 0 10px var(--glow);
  }

  .theme-btn {
    background: transparent; border: 1px solid var(--border);
    color: var(--cobalt); cursor: pointer; border-radius: 4px; padding: 4px 8px;
  }

  main { max-width: 1200px; margin: 0 auto; padding: 3rem; animation: fadeIn 0.3s ease-out; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  footer { text-align: center; padding: 2rem; font-family: 'JetBrains Mono', monospace; color: var(--text-dim); }
  .terminal-prompt { color: var(--cobalt); }

  pre.mermaid {
    display: flex; justify-content: center; margin: 2rem 0;
    padding: 1rem; background: transparent; border: none; overflow: auto;
  }

  pre.mermaid[data-processed] svg { max-width: 100%; height: auto; }

  pre.mermaid svg .node rect, pre.mermaid svg .node polygon { fill: var(--bg-card) !important; stroke: var(--cobalt) !important; }
  pre.mermaid svg text { fill: var(--text) !important; }
  pre.mermaid svg .edgePath path { stroke: var(--cobalt) !important; }

  @media (max-width: 768px) {
    .circuit-svg, .node-label { display: none; }
    main { padding: 1.5rem; }
    .nav-links { gap: 1rem; }
  }
</style>
