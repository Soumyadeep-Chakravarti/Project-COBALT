---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | c0balt</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress"></div>
    <nav class="logic-gate-nav">
      <!-- Main trunk SVG -->
      <svg class="circuit-svg" viewBox="0 0 400 80" preserveAspectRatio="none">
        <!-- Main trunk line -->
        <path class="circuit-line" d="M 20 75 L 20 40 L 380 40" />
        <!-- Branch to logs -->
        <path class="circuit-line branch-logs" d="M 70 40 L 70 30" />
        <!-- Branch to stack -->
        <path class="circuit-line branch-stack" d="M 150 40 L 150 30" />
        <!-- Branch to arch -->
        <path class="circuit-line branch-arch" d="M 230 40 L 230 30" />
        <!-- Branch to search -->
        <path class="circuit-line branch-search" d="M 310 40 L 310 30" />
        <!-- Active glow bead -->
        <circle class="data-bead" cx="20" cy="75" r="4">
          <animateMotion dur="3s" repeatCount="indefinite" path="M 20 75 L 20 40 L 380 40" />
        </circle>
      </svg>
      
      <div class="nav-content">
        <a href="/" class="logo">
          <span class="bracket">[</span>c0balt<span class="bracket">]</span>
        </a>
        <div class="nav-links">
          <a href="/logs" class="nav-node" data-branch="logs">
            <span class="node-dot"></span>
            <span class="node-label">logs</span>
          </a>
          <a href="/stack" class="nav-node" data-branch="stack">
            <span class="node-dot"></span>
            <span class="node-label">stack</span>
          </a>
          <a href="/architecture" class="nav-node" data-branch="arch">
            <span class="node-dot"></span>
            <span class="node-label">arch</span>
          </a>
          <a href="/search" class="nav-node" data-branch="search">
            <span class="node-dot"></span>
            <span class="node-label">search</span>
          </a>
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
            <span class="sun-icon">☀</span>
            <span class="moon-icon">☾</span>
          </button>
          <a href="https://github.com/Soumyadeep-Chakravarti" target="_blank" class="nav-node">
            <span class="node-dot"></span>
            <span class="node-label">gh</span>
          </a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <span class="terminal-prompt">></span> abstraction is a weapon
    </footer>
    <script>
      const progress = document.getElementById('scroll-progress');
      window.addEventListener('scroll', () => {
        const scrolled = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        progress.style.width = scrolled + '%';
      });

      // Theme toggle
      const themeBtn = document.getElementById('theme-toggle');
      themeBtn?.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --cobalt: #00d4ff;
    --cobalt-dim: #0088aa;
    --bg-dark: #0a0a0f;
    --bg-card: #12121a;
    --text: #e0e0e0;
    --text-dim: #666;
    --accent: #ff3366;
    --success: #00ff88;
    --warning: #ffaa00;
    --glow: rgba(0, 212, 255, 0.4);
    --border: rgba(0, 212, 255, 0.15);
  }

  :root.light {
    --cobalt: #0891b2;
    --cobalt-dim: #0e7490;
    --bg-dark: #f8fafc;
    --bg-card: #f1f5f9;
    --text: #1e293b;
    --text-dim: #64748b;
    --accent: #e11d48;
    --success: #059669;
    --warning: #d97706;
    --glow: rgba(8, 145, 178, 0.3);
    --border: rgba(8, 145, 178, 0.2);
  }

  :root {
    --neon-pink: #ff0080;
    --neon-cyan: #00ffff;
    --neon-purple: #a855f7;
    --neon-green: #00ff88;
  }

  :root.light {
    --neon-pink: #db2777;
    --neon-cyan: #0891b2;
    --neon-purple: #7c3aed;
    --neon-green: #059669;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: 'Outfit', sans-serif;
    background: var(--bg-dark);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    background: var(--bg-dark);
  }

  main {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--cobalt);
    box-shadow: 0 0 10px var(--cobalt), 0 0 20px var(--cobalt);
    z-index: 1001;
    transition: width 0.1s;
    animation: scrollGlow 1.5s ease-in-out infinite;
  }

  @keyframes scrollGlow {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 1; }
  }

  .logic-gate-nav {
    display: grid;
    grid-template-columns: 1fr;
    padding: 0.5rem 2rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-dark);
    position: sticky;
    top: 0;
    z-index: 100;
    overflow: visible;
  }

  .circuit-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.15;
  }

  .circuit-line {
    fill: none;
    stroke: var(--cobalt);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .data-bead {
    fill: var(--cobalt);
    filter: drop-shadow(0 0 6px var(--cobalt));
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  :root.light .circuit-svg {
    opacity: 0.1;
  }

  .nav-node {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.6rem;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .nav-node:hover {
    background: rgba(0, 212, 255, 0.1);
  }

  .node-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cobalt);
    opacity: 0.3;
    transition: all 0.3s ease;
  }

  .nav-node:hover .node-dot {
    opacity: 1;
    box-shadow: 0 0 6px var(--cobalt);
  }

  .node-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .nav-node:hover .node-label {
    color: var(--cobalt);
  }

  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cobalt);
    text-decoration: none;
    letter-spacing: -1px;
    animation: neonGlow 2s ease-in-out infinite alternate;
  }

  @keyframes neonGlow {
    from {
      text-shadow: 0 0 4px var(--cobalt), 0 0 10px var(--cobalt), 0 0 20px var(--cobalt);
    }
    to {
      text-shadow: 0 0 2px var(--cobalt), 0 0 5px var(--cobalt), 0 0 10px var(--cobalt);
    }
  }

  .bracket {
    color: var(--text-dim);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .theme-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--cobalt);
    padding: 0.4rem 0.6rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-btn:hover {
    border-color: var(--cobalt);
    box-shadow: 0 0 15px var(--glow);
  }

  .sun-icon { display: none; }
  .moon-icon { display: block; }

  :root.light .sun-icon { display: block; }
  :root.light .moon-icon { display: none; }

  .nav-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 1px;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--cobalt);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--cobalt);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    border-top: 1px solid rgba(0, 212, 255, 0.1);
  }

  .terminal-prompt {
    color: var(--cobalt);
    animation: cursorBlink 1s step-end infinite, cursorGlow 2s ease-in-out infinite alternate;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
  }

  @keyframes cursorGlow {
    from { text-shadow: 0 0 3px var(--cobalt); }
    to { text-shadow: 0 0 12px var(--cobalt), 0 0 20px var(--cobalt); }
  }

  /* Syntax highlighting overrides */
  pre code.hljs {
    background: var(--bg-card);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    border: 1px solid var(--border);
  }

  code.hljs {
    background: var(--bg-card);
    padding: 0.2rem 0.4rem;
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .logic-gate-nav {
      padding: 0.5rem 1rem;
    }
    .nav-content {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .circuit-svg {
      display: none;
    }
    .node-label {
      display: none;
    }
    main {
      padding: 1.5rem;
    }
  }
</style>